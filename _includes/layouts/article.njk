<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} | Hasham Ahmad</title>
  <meta name="description" content="{{ description }}">
  <meta name="theme-color" content="#fbfaf7">
  <link rel="stylesheet" href="../styles.css">
  <link rel="stylesheet" href="../personal.css">
  {% include "analytics.njk" %}
</head>
<body class="article-page" data-page="insights">
  <a class="skip-link" href="#main-content">Skip to content</a>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="../index.html" aria-label="Hasham Ahmad, home"><span class="brand-mark" aria-hidden="true">HA</span><span class="brand-text">Hasham Ahmad</span></a>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav" aria-label="Open navigation">Menu</button>
      <nav class="main-nav" id="main-nav" aria-label="Main navigation">
        <a href="../index.html" data-nav="home">Home</a><a href="../work.html" data-nav="work">Work</a><a href="../blog.html" data-nav="insights">Writing</a><a href="../about.html" data-nav="about">About</a><a class="nav-cta" href="../contact.html" data-nav="contact">Say hello</a>
      </nav>
    </div>
  </header>

  <div class="page-wrapper">
    <main class="main-content" id="main-content">
      <article class="blog-post">
        <header class="post-header">
          <p class="post-meta">{{ dateDisplay }} · {{ readTime }}</p>
          <h1 class="post-title-full">{{ title }}</h1>
        </header>
        <div class="post-content">
          {{ content | safe }}
        </div>
        <footer class="post-footer">
          {% if topicTags %}<div class="post-tags">{% for tag in topicTags %}<span class="tag">{{ tag }}</span>{% endfor %}</div>{% endif %}
          <div class="post-nav"><a href="../blog.html" class="back-to-blog">← Back to all writing</a></div>
        </footer>
      </article>
    </main>

    <aside class="sidebar">
      <section class="sidebar-section"><h3>Get in touch</h3><p><a href="mailto:hasham87@gmail.com">hasham87@gmail.com</a></p></section>
      <section class="sidebar-section"><h3>Follow me</h3><ul class="social-links"><li><a href="https://www.linkedin.com/in/hashamahmad/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li><li><a href="https://github.com/hassham" target="_blank" rel="noopener noreferrer">GitHub</a></li></ul></section>
      <section class="sidebar-section"><h3>More writing</h3><ul class="social-links">{% for post in collections.publishedPosts %}{% if post.url != page.url %}<li><a href="..{{ post.url }}">{{ post.data.title }}</a></li>{% endif %}{% endfor %}</ul></section>
    </aside>
  </div>

  <footer class="site-footer"><div class="container"><div class="footer-grid"><div class="footer-brand"><strong>Hasham Ahmad</strong><p>Software engineer, pragmatic solutions architect, and always curious about a better way to build.</p></div><nav class="footer-links" aria-label="Footer navigation"><strong>Explore</strong><a href="../work.html">Work</a><a href="../blog.html">Writing</a><a href="../about.html">About</a></nav><div class="footer-links"><strong>Connect</strong><a href="mailto:hasham87@gmail.com">Email</a><a href="https://www.linkedin.com/in/hashamahmad/" target="_blank" rel="noopener noreferrer">LinkedIn</a><a href="https://github.com/hassham" target="_blank" rel="noopener noreferrer">GitHub</a></div></div><div class="footer-bottom"><span>© <span data-current-year>2026</span> Hasham Ahmad</span><span>Made in Sydney, Australia</span></div></div></footer>
  <script src="../script.js"></script>
</body>
</html>
